# 복사해서 .env 파일로 만들고 값 채우기
# cp scripts/.env.sample scripts/.env

# OpenAI API 키 (필수)
OPENAI_API_KEY=sk-proj-여기에_API_키_입력

# LinkedIn API (linkedin_post.py 사용 시)
LINKEDIN_ACCESS_TOKEN=AQX여기에_액세스_토큰
LINKEDIN_PERSON_URN=urn:li:person:여기에_URN

# LinkedIn 브라우저 자동화 모드 사용 시
LINKEDIN_EMAIL=your@email.com
LINKEDIN_PASSWORD=yourpassword
